


{% liquid
  assign header_style = 'header-style-1'
  assign enable_sticky = section.settings.sticky_header
  assign enable_transparent = section.settings.enable_transparent
  assign logo = section.settings.logo_image | default: settings.logo
  assign menu = section.settings.menu | default: section.settings.menu
%}

<div class="premium-header-wrapper {{ header_style }}{% if enable_sticky %} premium-header--sticky{% endif %}{% if enable_transparent %} premium-header--transparent{% endif %}" data-section-id="{{ section.id }}">
  
  <!-- Mobile Menu Overlay -->
  <div class="premium-header__mobile-menu" id="mobile-menu-{{ section.id }}">
    <button class="premium-header__mobile-close" aria-label="{{ 'general.close' | t }}">
      <span class="svg-wrapper">{{ 'icon-close.svg' | inline_asset_content }}</span>
    </button>
    
    {% if menu %}
      <ul class="premium-header__mobile-nav">
        {% for link in linklists[menu].links %}
          <li>
            <a href="{{ link.url }}">{{ link.title }}</a>
          </li>
        {% endfor %}
      </ul>
    {% endif %}
  </div>

  <!-- Main Header -->
  <header class="premium-header page-width">
    
    <!-- Left: Logo / Mobile Toggle -->
    <div class="premium-header__left">
      <a href="{{ routes.root_url }}" class="premium-header__logo">
        {% if logo %}
          {{ logo | image_url: width: 200 | image_tag: 
            class: 'premium-header__logo-img',
            loading: 'lazy',
            alt: logo.alt | default: shop.name | escape
          }}
        {% else %}
          <span>{{ shop.name }}</span>
        {% endif %}
      </a>
    </div>

    <!-- Center: Desktop Nav -->
    <nav class="premium-header__nav" role="navigation" aria-label="{{ 'general.navigation' | t }}">
      {% if menu %}
        <ul>
          {% for link in linklists[menu].links %}
            <li>
              <a href="{{ link.url }}">{{ link.title }}</a>
            </li>
          {% endfor %}
        </ul>
      {% endif %}
    </nav>

    <!-- Right: Icons + Mobile Hamburger -->
    <div class="premium-header__right">
      
      {% if section.settings.search_icon %}
        <a href="#" class="premium-header__icon premium-header__search-toggle" aria-label="{{ 'general.search.search' | t }}">
          <span class="svg-wrapper">{{ 'icon-search.svg' | inline_asset_content }}</span>
        </a>
      {% endif %}

      {% if section.settings.account_icon and shop.customer_accounts_enabled %}
        <a href="{% if customer %}{{ routes.account_url }}{% else %}{{ routes.account_login_url }}{% endif %}" 
           class="premium-header__icon" rel="nofollow" aria-label="{{ 'customer.account' | t }}">
          <span class="svg-wrapper">{{ 'icon-account.svg' | inline_asset_content }}</span>
        </a>
      {% endif %}

      <!-- Cart -->
      <a href="{{ routes.cart_url }}" class="premium-header__icon" id="cart-icon-{{ section.id }}" aria-label="{{ 'templates.cart.cart' | t }}">
        <span class="svg-wrapper">{{ 'icon-cart.svg' | inline_asset_content }}</span>
        <span class="premium-header__cart-count" style="display: none;">{{ cart.item_count }}</span>
      </a>

      <!-- Mobile Hamburger -->
      <button class="premium-header__icon premium-header__mobile-menu-toggle hamburger" aria-label="{{ 'general.menu' | t }}" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </header>

  <!-- Search Modal -->
  {% if section.settings.search_icon %}
    <div class="premium-header__search-modal" id="search-modal-{{ section.id }}">
      <div class="premium-header__search-form">
        <form action="{{ routes.search_url }}" method="get" role="search">
          <input 
            type="search" 
            class="premium-header__search-input" 
            name="q"
            placeholder="{{ 'general.search.search' | t }}"
            aria-label="{{ 'general.search.search' | t }}"
          >
          <input type="hidden" name="options[prefix]" value="last">
        </form>
      </div>
    </div>
  {% endif %}

</div>

{{ 'premium-header.css' | asset_url | stylesheet_tag }}
{{ 'premium-header.js' | asset_url | script_tag }}

